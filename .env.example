APP_TZ=Asia/Tokyo

SITE_DOMAIN=
ACME_EMAIL=admin@example.com

# ── MySQL ──────────────────────────────────────────────────────
MYSQL_DATABASE=mountain_db
MYSQL_USER=mountain_user
MYSQL_PASSWORD=change-this-db-password
# Xserver의 경우 localhost, AWS RDS의 경우 엔드포인트 주소
RDS_ENDPOINT=localhost

# ── Mail ───────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-mail-app-password
MAIL_TO=info@for-mountain.co.jp

# ── JWT & Admin ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=change-this-admin-password

# ── Frontend ───────────────────────────────────────────────────
APP_FRONTEND_BASE_URL=https://your-domain.com
FRONTEND_PORT=3000
FRONTEND_BIND_HOST=127.0.0.1

# ── AWS S3 ─────────────────────────────────────────────────────
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-bucket-name
S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-northeast-1.amazonaws.com

# ── Redis (Upstash 사용 시) ────────────────────────────────────
# https://upstash.com 에서 무료 Redis 생성 후 아래 값 입력
SPRING_DATA_REDIS_HOST=your-redis.upstash.io
SPRING_DATA_REDIS_PORT=6380
SPRING_DATA_REDIS_PASSWORD=your-upstash-redis-password
SPRING_DATA_REDIS_SSL=true
