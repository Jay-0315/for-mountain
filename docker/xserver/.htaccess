Options -Indexes
RewriteEngine On

# HTTP → HTTPS 강제 전환
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 403/404 에러 방어막
ErrorDocument 403 /index.html
ErrorDocument 404 /index.html

# API → PHP 프록시
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/v1/(.*)$ /proxy.php [QSA,L]

# 업로드 파일 → PHP 프록시
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^uploads/(.*)$ /proxy.php [QSA,L]

# 동적 라우트 → placeholder HTML
RewriteRule ^services/(?!_$)([^/]+)/?$ /services/_/index.html [L]
RewriteRule ^news/(?!_$)([^/]+)/?$ /news/_/index.html [L]

# SPA 폴백
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]
